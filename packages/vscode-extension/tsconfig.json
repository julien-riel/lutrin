{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    // the tests import the sources under their REAL name ("./x.ts"): Node
    // resolves ESM specifiers down to the extension and rewrites nothing.
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "vscode"]
  },
  "include": ["src/**/*.ts", "test/**/*.mts"]
}
